<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Join / Donate - EcoSwap</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-5">
<h2 class="text-center mb-4">Join / Donate</h2>

<form id="joinForm" class="mx-auto" style="max-width:600px;">
<div class="mb-3">
<input type="text" class="form-control" id="name" placeholder="Full Name" required>
</div>
<div class="mb-3">
<input type="email" class="form-control" id="email" placeholder="Email" required>
</div>
<div class="mb-3">
<input type="tel" class="form-control" id="phone" placeholder="Phone" required>
</div>
<div class="mb-3">
<select class="form-select" id="type" required>
<option selected disabled>Select Contribution Type</option>
<option value="bottles">Plastic Bottles</option>
<option value="bags">Plastic Bags</option>
</select>
</div>
<div class="mb-3">
<input type="number" class="form-control" id="quantity" placeholder="Quantity" required>
</div>
<button type="submit" class="btn btn-success w-100">Submit</button>
</form>
</div>

<script>
document.getElementById('joinForm').addEventListener('submit', function(e){
    e.preventDefault();
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const phone = document.getElementById('phone').value;
    const type = document.getElementById('type').value;
    const quantity = document.getElementById('quantity').value;

    // Fetch existing data from localStorage
    let donations = JSON.parse(localStorage.getItem('donations')) || [];

    // Add new donation/join entry
    donations.push({name, email, phone, type, quantity, date: new Date().toLocaleString()});

    // Save back to localStorage
    localStorage.setItem('donations', JSON.stringify(donations));

    alert("Thank you for joining/donating!");
    this.reset();
});
</script>
</body>
</html>