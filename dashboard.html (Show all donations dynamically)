<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard - EcoSwap</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body {
    font-family: 'Poppins', sans-serif;
}
.sidebar {
    background:#2E7D32;
    min-height:100vh;
    color:white;
}
.sidebar a {
    color:white;
    display:block;
    padding:15px;
    text-decoration:none;
}
.sidebar a:hover {
    background:#1b4f26;
}
.content {
    padding:20px;
}
table th, table td {
    text-align:center;
}
</style>
</head>
<body>

<div class="d-flex">
<div class="sidebar" style="width:220px;">
<h3 class="text-center py-3">EcoSwap Admin</h3>
<a href="#">Dashboard</a>
<a href="#" onclick="clearData()">Clear All Data</a>
<a href="login.html">Logout</a>
</div>

<div class="content flex-fill">
<h2>All Join / Donation Entries</h2>
<table class="table table-striped mt-4">
<thead class="table-success">
<tr>
<th>#</th>
<th>Name</th>
<th>Email</th>
<th>Phone</th>
<th>Type</th>
<th>Quantity</th>
<th>Date</th>
</tr>
</thead>
<tbody id="donationTable"></tbody>
</table>
</div>
</div>

<script>
function loadData(){
    const donations = JSON.parse(localStorage.getItem('donations')) || [];
    const table = document.getElementById('donationTable');
    table.innerHTML = "";
    donations.forEach((item, index) => {
        table.innerHTML += `<tr>
        <td>${index+1}</td>
        <td>${item.name}</td>
        <td>${item.email}</td>
        <td>${item.phone}</td>
        <td>${item.type}</td>
        <td>${item.quantity}</td>
        <td>${item.date}</td>
        </tr>`;
    });
}
function clearData(){
    if(confirm("Are you sure you want to clear all data?")){
        localStorage.removeItem('donations');
        loadData();
    }
}
window.onload = loadData;
</script>

</body>
</html>