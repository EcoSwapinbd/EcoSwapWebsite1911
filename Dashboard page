<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">

<title>EcoSwap Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#e0f7e9;
}

</style>

</head>

<body>

<div class="container mt-5">

<h2>Donations Dashboard</h2>

<table class="table table-bordered">

<thead>

<tr>

<th>#</th>
<th>Name</th>
<th>Phone</th>
<th>Type</th>
<th>Quantity</th>

</tr>

</thead>

<tbody id="data"></tbody>

</table>

</div>

<script>

let data=JSON.parse(localStorage.getItem("donations"))||[]

let table=document.getElementById("data")

data.forEach((d,i)=>{

table.innerHTML+=`

<tr>

<td>${i+1}</td>
<td>${d.name}</td>
<td>${d.phone}</td>
<td>${d.type}</td>
<td>${d.quantity}</td>

</tr>

`

})

</script>

</body>
</html>
```
